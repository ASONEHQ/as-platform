# Local development only. These values are fictitious and must never be reused in production.
NODE_ENV=development
APP_NAME=asone-api
APP_VERSION=0.1.0-local
LOG_LEVEL=debug
API_HOST=127.0.0.1
API_PORT=3000
AUTH_JWT_ISSUER=https://api.local.asone.mx
AUTH_JWT_AUDIENCE=asone-api-local
# Fictitious development-only value. Generate an independent high-entropy secret per environment.
AUTH_ACCESS_TOKEN_SECRET=local_only_replace_with_at_least_32_random_characters
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_TTL_SECONDS=2592000
AUTH_LOGIN_RATE_LIMIT_MAX=10
AUTH_LOGIN_RATE_LIMIT_WINDOW_MS=60000
OPENAPI_UI_ENABLED=true
METRICS_ENABLED=true
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW_MS=60000
REQUEST_BODY_LIMIT_BYTES=1048576
REQUEST_TIMEOUT_MS=30000
KEEP_ALIVE_TIMEOUT_MS=72000
TRUST_PROXY=false

POSTGRES_DB=asone_local
POSTGRES_USER=asone_local
POSTGRES_PASSWORD=local_postgres_password_change_me
POSTGRES_PORT=5432
DATABASE_URL=postgresql://asone_local:local_postgres_password_change_me@127.0.0.1:5432/asone_local
# Optional integration-test database. Its database name must contain "test".
DATABASE_TEST_URL=postgresql://asone_test:local_test_password_change_me@127.0.0.1:5432/asone_test

REDIS_PASSWORD=local_redis_password_change_me
REDIS_PORT=6379
REDIS_URL=redis://:local_redis_password_change_me@127.0.0.1:6379

MINIO_ROOT_USER=asone_local_minio
MINIO_ROOT_PASSWORD=local_minio_password_change_me
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025
