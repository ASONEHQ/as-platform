{
  "name": "@asone/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@asone/config": "workspace:*",
    "@asone/database": "workspace:*",
    "@asone/errors": "workspace:*",
    "@asone/logger": "workspace:*",
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.6.1",
    "@fastify/swagger-ui": "5.2.3",
    "fastify": "^5.6.2",
    "pino": "^10.3.0",
    "prom-client": "^15.1.3",
    "redis": "^5.10.0"
  },
  "devDependencies": {
    "@asone/typescript-config": "workspace:*",
    "@types/node": "^24.10.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
